# ============================================================
#  CONFIGURACIÓN DE FSPORTS — copiá este archivo como .env.local
# ============================================================

# Modo de datos. Opciones:
#   manual -> lee src/data/manifest.ts (editable a mano, sin internet). RECOMENDADO.
#   api    -> datos en vivo de football-data.org y Jolpica-F1 (requiere token abajo).
#   demo   -> datos de ejemplo abundantes, para desarrollo y capturas.
VITE_DATA_MODE=manual

# Token de football-data.org (solo necesario si VITE_DATA_MODE=api).
# Se consigue gratis en https://www.football-data.org/client/register
VITE_FOOTBALL_DATA_TOKEN=

# URL base de la API de fútbol. Solo cambiala si configurás un proxy
# (por ejemplo un Cloudflare Worker) para evitar problemas de CORS.
VITE_FOOTBALL_API_BASE=https://api.football-data.org/v4
